// College Coach — Database Schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  name      String
  role      String   @default("student") // student | parent
  grade     Int      @default(7)         // current grade level (6-12)
  interests String?                      // comma-separated interests
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  goals         Goal[]
  milestones    MilestoneProgress[]
  chatMessages  ChatMessage[]
  weeklyCheckins WeeklyCheckIn[]
}

model Goal {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  category    String   // Academic | Extracurricular | PersonalGrowth | CollegePrep
  status      String   @default("not_started") // not_started | in_progress | done
  targetDate  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model MilestoneProgress {
  id          String   @id @default(cuid())
  userId      String
  grade       Int      // which grade this milestone belongs to
  pillar      String   // Academics | Extracurriculars | Skills | CollegePrep | PersonalGrowth
  milestoneKey String  // unique key matching knowledge base item
  title       String
  isComplete  Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, milestoneKey])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String   // user | assistant | system
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model WeeklyCheckIn {
  id            String   @id @default(cuid())
  userId        String
  weekOf        DateTime
  wentWell      String?
  wasHard       String?
  nextWeekPlan  String?
  aiSummary     String?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
