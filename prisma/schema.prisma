// College Coach — Database Schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  name      String
  role      String   @default("student") // student | parent
  grade     Int      @default(7)         // current grade level (6-12)
  interests String?                      // comma-separated interests
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  goals         Goal[]
  milestones    MilestoneProgress[]
  chatMessages  ChatMessage[]
  weeklyCheckins WeeklyCheckIn[]
  reportCards   ReportCard[]
}

model Goal {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  category    String   // Academic | Extracurricular | PersonalGrowth | CollegePrep
  status      String   @default("not_started") // not_started | in_progress | done
  targetDate  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model MilestoneProgress {
  id          String   @id @default(cuid())
  userId      String
  grade       Int      // which grade this milestone belongs to
  pillar      String   // Academics | Extracurriculars | Skills | CollegePrep | PersonalGrowth
  milestoneKey String  // unique key matching knowledge base item
  title       String
  isComplete  Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, milestoneKey])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String   // user | assistant | system
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model WeeklyCheckIn {
  id            String   @id @default(cuid())
  userId        String
  weekOf        DateTime
  wentWell      String?
  wasHard       String?
  nextWeekPlan  String?
  aiSummary     String?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model ReportCard {
  id         String         @id @default(cuid())
  userId     String
  schoolYear String         // e.g., "2025-2026"
  term       String         // e.g., "Fall", "Spring", "Q1", "Semester 1"
  grade      Int            // grade level (6-12)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  user     User           @relation(fields: [userId], references: [id])
  subjects SubjectGrade[]

  @@unique([userId, schoolYear, term, grade])
}

model SubjectGrade {
  id                String   @id @default(cuid())
  reportCardId      String
  subject           String   // display name: "Math", "English Language Arts"
  normalizedSubject String?  // canonical key: "math", "ela" (for trend tracking)
  gradeType         String   @default("percentage") // percentage | letter | pass_fail
  rawGrade          String   // exactly what user entered: "92", "B+", "Pass"
  percentage        Float?   // numeric percentage (null for pass/fail)
  letterGrade       String?  // computed letter grade (null for pass/fail)
  includeInAnalysis Boolean  @default(true)
  notes             String?
  createdAt         DateTime @default(now())

  reportCard ReportCard @relation(fields: [reportCardId], references: [id], onDelete: Cascade)
}
